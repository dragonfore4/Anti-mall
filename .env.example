# ============================================================
# ตัวอย่าง environment variables — คัดลอกเป็น .env.local แล้วใส่ค่าจริง
# (.env.local ไม่ขึ้น git) · รีสตาร์ท dev server ทุกครั้งที่แก้
# ============================================================

# --- Supabase (auth + ฐานข้อมูล cloud) -----------------------
# URL ของโปรเจ็ค Supabase — เปิด public ได้ (เป็นแค่ที่อยู่ API)
# ที่มา: Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://ehnlcmkkajowcqabojbv.supabase.co

# anon (public) key — ใช้ฝั่ง browser, "เปิดเผยได้โดยตั้งใจ"
# สิทธิ์ถูกจำกัดด้วย RLS (ผู้ใช้เห็น/แก้เฉพาะข้อมูลตัวเอง)
# NEXT_PUBLIC_ = ตั้งใจให้ bundle ไปฝั่ง client
# ที่มา: Settings → API → Project API keys → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVobmxjbWtrYWpvd2NxYWJvamJ2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE0MzQ0MTIsImV4cCI6MjA5NzAxMDQxMn0.PU5a090qbB4ZTHc0FF5Ob4inqLcgkJK_MOmOoB1zL3c

# service_role key — สิทธิ์ "เต็ม" ข้าม RLS เห็น/แก้ข้อมูลทุกคน
# ⚠️ ความลับสุดยอด: ห้ามขึ้น git, ห้ามใส่ NEXT_PUBLIC_, ห้ามใช้ฝั่ง browser
#    (ไม่มี NEXT_PUBLIC_ prefix → Next.js ไม่ bundle ไป client)
# ใช้เฉพาะฝั่ง server (เช่นหน้า /dashboard ที่ต้องอ่าน profiles ทุกคน)
# ที่มา: Settings → API → Project API keys → service_role  (กด reveal)
SUPABASE_SERVICE_ROLE_KEY=<ใส่ service_role key ที่นี่ — ห้าม commit>

# --- OpenRouteService (ดัดเส้นทางให้เกาะถนนจริง) --------------
# key ฝั่ง server เท่านั้น (ไม่ใส่ NEXT_PUBLIC_) แนบตอนเรียก ORS
# ไม่ใส่ก็รันได้ — เส้นทางจะ fallback เป็นเส้นตรง (ไม่เกาะถนน)
# ที่มา: openrouteservice.org/dev → Dashboard → Token
ORS_API_KEY=<ใส่ ORS API key ที่นี่ — ห้าม commit ค่าจริง>
